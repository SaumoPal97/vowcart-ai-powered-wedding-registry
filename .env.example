# ---------------------------------------------------------------------------
# VowCart local development against REAL AWS (Aurora PostgreSQL + DynamoDB).
# Copy to `.env.local` (gitignored) and fill in. Next.js auto-loads it.
#
# Leave everything blank to run in seed-fallback mode (no AWS needed).
# As soon as PGHOST + AWS_REGION are set, the app talks to real Aurora.
# As soon as DYNAMODB_TABLE_NAME + AWS_REGION are set, it talks to real DynamoDB.
# ---------------------------------------------------------------------------

# --- AWS credentials (local) ----------------------------------------------
# Locally the app uses the DEFAULT AWS credential chain. Easiest options:
#   1. Put keys here (this file feeds process.env), OR
#   2. Use an AWS profile: set AWS_PROFILE and leave the keys blank.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=my-profile
# AWS_ROLE_ARN is only used on Vercel (OIDC). Leave blank for local.
AWS_ROLE_ARN=

# --- Aurora PostgreSQL ------------------------------------------------------
PGHOST=your-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
# Simplest for local dev: use the master password (skips IAM DB auth setup).
# Leave PGPASSWORD blank to use IAM token auth instead (needs rds_iam user +
# rds-db:connect permission on the IAM principal above).
PGPASSWORD=

# --- DynamoDB (single table, composite PK/SK, TTL on attribute `ttl`) -------
DYNAMODB_TABLE_NAME=vowcart
DYNAMODB_TABLE_PARTITION_KEY=PK
DYNAMODB_TABLE_SORT_KEY=SK
# Optional: only if DynamoDB is in a different region/role than Aurora.
# DYNAMODB_AWS_REGION=us-east-1
# DYNAMODB_AWS_ROLE_ARN=

# --- App --------------------------------------------------------------------
# Random string used to sign the login session cookie.
SESSION_SECRET=change-me-to-a-long-random-string
# Protects POST /api/admin/setup (schema migrate + seed).
ADMIN_SETUP_TOKEN=some-secret-token

# --- AI recommendations (optional) -----------------------------------------
# Without this, recommendations use the built-in rule-based curator.
# AI_GATEWAY_API_KEY=
